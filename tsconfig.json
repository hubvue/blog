{
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["dom", "ESNext"],
    "jsx": "react",
    "paths": {
      "@/*": ["./"]
    },
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": true,
    "skipLibCheck": true,
    "typeRoots": ["node_modules/@types", "./src/global.d.ts"],
    "types": []
  },
  "include": ["src/**/*"]
}
